script WaddleDeeTown_Lab_BinderCheck7
{
    msgbox("{SPEAKER NAME_WISE}Magnificent! You've already registered
            150 Helpers!
            
            As proof of your hard work, please
            accept this care package from me!")
    giveitem_msg(WaddleDeeTown_Lab_ReceivedExpCharm, ITEM_EXP_CHARM, 1, MUS_RG_OBTAIN_KEY_ITEM)
    giveitem(ITEM_TM06)
    giveitem(ITEM_BIG_NUGGET)
    giveitem(ITEM_MASTER_BALL)
    msgbox("{SPEAKER NAME_WISE}It includes a TM, a new Heart, some
            valuables, and most importantly:
            the Experience Charm!
            
            This is the ultimate tool to bolster
            your party's experience gains.
            
            Evolving Helpers should be easier
            than ever with this by your side.
            
            And if there any uncaptured Helpers
            still eluding you, I've bestowed
            the ultimate Heart unto you as well.
            
            The Master Heart can never fail.
            Use it wisely, my good friend!")
    setflag(FLAG_BINDER_GATE_07)
}

script WaddleDeeTown_Lab_EvaluateCards
{
    setvar(VAR_0x8004, 0)
	specialvar(VAR_RESULT, ScriptGetPokedexInfo)
	copyvar(VAR_0x8008, VAR_0x8005)
	copyvar(VAR_0x8009, VAR_0x8006)
	copyvar(VAR_0x800A, VAR_RESULT)
	buffernumberstring(STR_VAR_2, VAR_0x8009)
}

script WaddleDeeTown_Lab_EventScript_TurnLeft
{
    turnobject(LOCALID_LAB_RECEPTIONIST_LEFT, DIR_EAST)
    goto(WaddleDeeTown_Lab_EventScript_LeftReceptionist)
}

script WaddleDeeTown_Lab_EventScript_TurnRight
