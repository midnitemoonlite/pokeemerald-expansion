script WaddleDeeTown_Lab_EventScript_WiseGateCheckSuccess
{
    msgbox("{SPEAKER NAME_WISE}Excellent! You've already recruited
            {STR_VAR_2} Helpers so far!
            
            As promised, here's your care package!")
    giveitem_msg(WaddleDeeTown_Lab_ReceivedHelperBoxLink, ITEM_POKEMON_BOX_LINK, 1, MUS_RG_OBTAIN_KEY_ITEM)
    giveitem(ITEM_TM02)
    giveitem(ITEM_STARDUST)
    giveitem(ITEM_POKE_BALL, 10)
    setflag(FLAG_BINDER_GATE_01)
    msgbox("{SPEAKER NAME_WISE}A rather generous selection, is it not?
            The Helper Box Link is especially handy.
            
            Use it, and you can access your Helper
            boxes anywhere, without needing a PC!
            
            Hopefully this serves as an added
            incentive to work on your Info Cards\.
            not that knowledge isn't reward enough!")
    closemessage()
    applymovement(LOCALID_LAB_WISE, moves(walk_in_place_down * 2))
    waitmovement()
    msgbox("{SPEAKER NAME_WISE}And as for you, Bandana Waddle Dee\.
            I've told the king that I would bring
            you on as a personal assistant.
            
            You and I are both eager to uncover
            where all these Helpers came from, yes?
            
            {SPEAKER NAME_BANDANA}Yes! About that, actually\.
            I got some intel asking around town.
            
            It seems the Great King has ordered for
            the town's top exit to be sealed off.
            
            Perhaps something unusual has
            happened in that area?
            
            {SPEAKER NAME_WISE}Hm\. even so, the town has been divided
            by an unscrupulous avalanche.
            
            You'll have to approach from the other
            side. That should also put you in
            the path of a few more Arenas.
            
            Perhaps then, you might become ready
            to face whatever threat lies ahead.
            
            But do be careful. I don't wish for
            either of you to endanger yourselves\.
            
            {SPEAKER NAME_BANDANA}Don't sweat it! Kirby's plenty strong,
            and I can keep up with him just fine!")
    closemessage()
    turnobject(LOCALID_PLAYER, DIR_EAST)
    turnobject(LOCALID_LAB_BWD, DIR_WEST)
    delay(30)
    msgbox("{SPEAKER NAME_BANDANA}First things first, though.
            My team and I need to visit the Arena!
            
            Kirby, why don't you get a head start
            over to the next Arena?
            
            The only way out of town right now is
            through Vegetable Valley to the east.
            
            Hopefully I can catch up with you
            soon enough!")
    closemessage()
    applymovement(LOCALID_LAB_BWD, moves(walk_right * 5, walk_down * 7))
    waitmovement()
    removeobject(LOCALID_LAB_BWD)
    setvar(VAR_WADDLE_DEE_TOWN_STATE, 5)
    setvar(VAR_WADDLE_DEE_TOWN_EAST_GATE, 1)
}

script WaddleDeeTown_Lab_EventScript_WiseGateCheckFailure
{
    msgbox("{SPEAKER NAME_WISE}Unfortunately, it seems you have only
            recruited {STR_VAR_2} Helpers\.
            
            Waddle Dee Town's park should have
            more than enough to meet this goal.
            
            Why don't you fill out your cards a
            bit, and then return here? I'll gift
            you your care package once you do.")
    release
}

script WaddleDeeTown_Lab_EventScript_WiseGateCheckRetry
{
    lockall
    specialvar(VAR_RESULT, GetPlayerFacingDirection)
    if(var(VAR_RESULT) == DIR_NORTH)
    {
        turnobject(LOCALID_LAB_BWD, DIR_NORTH)
        applymovement(LOCALID_PLAYER, moves(walk_down, walk_in_place_up))
    }
    elif(var(VAR_RESULT) == DIR_WEST)
    {
        turnobject(LOCALID_LAB_BWD, DIR_NORTH)
        applymovement(LOCALID_PLAYER, moves(walk_down, walk_left, walk_down, walk_in_place_up))
    }
    waitmovement()
    delay(15)
    applymovement(LOCALID_LAB_WISE, moves(walk_in_place_down))
    waitmovement()
    msgbox("{SPEAKER NAME_WISE}Welcome back, Kirby.
            Have you recruited {COLOR RED}6 Helpers{COLOR DARK_GRAY}?")
            call(WaddleDeeTown_Lab_EvaluateCards)
    if(var(VAR_0x8009) >= 6)
    {
        goto(WaddleDeeTown_Lab_EventScript_WiseGateCheckSuccess)
    }
    elif(var(VAR_0x8009) < 6)
    {
        goto(WaddleDeeTown_Lab_EventScript_WiseGateCheckFailure)
    }
}

script WaddleDeeTown_Lab_EventScript_InfoCardRating
{
    lock
    faceplayer
    msgbox("{SPEAKER NAME_WISE}Good to see you again, Kirby! Do you
            wish to present your Info Card Binder?", MSGBOX_YESNO)
    if(var(VAR_RESULT))
    {
        call(WaddleDeeTown_Lab_EvaluateCards)
        msgbox("{SPEAKER NAME_WISE}Let's see... you've recruited
                {STR_VAR_2} Helpers thus far.")
        if(var(VAR_0x8009) >= 15 && !flag(FLAG_BINDER_GATE_02))
        {
            call(WaddleDeeTown_Lab_BinderCheck2)
        }
        if(var(VAR_0x8009) >= 30 && !flag(FLAG_BINDER_GATE_03))
        {
            call(WaddleDeeTown_Lab_BinderCheck3)
        }
        if(var(VAR_0x8009) >= 50 && !flag(FLAG_BINDER_GATE_04))
        {
            call(WaddleDeeTown_Lab_BinderCheck4)
        }
        if(var(VAR_0x8009) >= 75 && !flag(FLAG_BINDER_GATE_05))
        {
            call(WaddleDeeTown_Lab_BinderCheck5)
        }
        if(var(VAR_0x8009) >= 100 && !flag(FLAG_BINDER_GATE_06))
        {
            call(WaddleDeeTown_Lab_BinderCheck6)
        }
        if(var(VAR_0x8009) >= 150 && !flag(FLAG_BINDER_GATE_07))
        {
            call(WaddleDeeTown_Lab_BinderCheck7)
        }
        goto_if_le(VAR_0x8009, 25, WaddleDeeTown_Lab_WiseAdvice01)
        goto_if_le(VAR_0x8009, 50, WaddleDeeTown_Lab_WiseAdvice02)
        goto_if_le(VAR_0x8009, 75, WaddleDeeTown_Lab_WiseAdvice03)
        goto_if_le(VAR_0x8009, 100, WaddleDeeTown_Lab_WiseAdvice04)
        goto_if_le(VAR_0x8009, 125, WaddleDeeTown_Lab_WiseAdvice05)
        goto_if_le(VAR_0x8009, 150, WaddleDeeTown_Lab_WiseAdvice06)
        goto_if_le(VAR_0x8009, 175, WaddleDeeTown_Lab_WiseAdvice07)
        goto_if_le(VAR_0x8009, 200, WaddleDeeTown_Lab_WiseAdvice08)
        goto_if_le(VAR_0x8009, 225, WaddleDeeTown_Lab_WiseAdvice09)
        goto_if_le(VAR_0x8009, 250, WaddleDeeTown_Lab_WiseAdvice10)
        goto_if_le(VAR_0x8009, 275, WaddleDeeTown_Lab_WiseAdvice11)
        goto_if_le(VAR_0x8009, 299, WaddleDeeTown_Lab_WiseAdvice11)
    }
    else
    {
        msgbox("{SPEAKER NAME_WISE}Still working hard on it, hm?
                Best of luck to you then!")
    }
    release
}

script WaddleDeeTown_Lab_WiseAdvice01
{
    msgbox("{SPEAKER NAME_WISE}You're still in the early stages of
            filling out your Info Card Binder.
            
            It may seem daunting, but don't fret!
            We believe in you, Kirby!")
    release
}

script WaddleDeeTown_Lab_WiseAdvice02
{
    msgbox("{SPEAKER NAME_WISE}Good, good. You're making steady
            progress on your Info Cards.
            
            If you spot a Helper you haven't yet
            recruited, the Info Cards can point
            you to their potential locations!")
    release
}

script WaddleDeeTown_Lab_WiseAdvice03
{
    msgbox("{SPEAKER NAME_WISE}Have you looked in places other than
            tall grass for Helpers, Kirby?
            
            Many fishers in town have reported
            hooking up Helpers, for example.")
    release
}

script WaddleDeeTown_Lab_WiseAdvice04
{
    msgbox("{SPEAKER NAME_WISE}Recently, I received a new report about
            the locations of certain Helpers.
            
            Apparently some hide within or disguise
            themselves as Star Blocks. Surprising!
            
            Kirby, do you have any means of
            investigating those?")
    release
}

script WaddleDeeTown_Lab_WiseAdvice05
{
    msgbox("{SPEAKER NAME_WISE}If you need new leads, retracing your
            steps may be a viable solution.
            
            You've travelled quite far now, and
            picked up a number of new tools.
            
            Try applying them to older areas; they
            may uncover new paths for you!")
    release
}

script WaddleDeeTown_Lab_WiseAdvice06
{
    msgbox("{SPEAKER NAME_WISE}By any chance, have you heard of the
            Merry Magocade?
            
            Games aren't quite my style, but I've
            heard there are certain Helpers you can
            only obtain in those walls.
            
            There's no harm in popping in for a quick
            visit, is there?")
    release
}

script WaddleDeeTown_Lab_WiseAdvice07
{
    msgbox("{SPEAKER NAME_WISE}What a major milestone! You're
            closer to the end than the beginning.
            
            Since you've come this far, I hope you'll
            see it through to the finish line!")
    release
}

script WaddleDeeTown_Lab_WiseAdvice08
{
    msgbox("{SPEAKER NAME_WISE}If you haven't hit it yet, there may
            come a time where you've recruited
            most wild Helpers already.
            
            The Info Cards can help you uncover 
            how to evolve Helpers you obtained.
            
            Some conditions are rather obtuse,
            so give it a look if you're stumped!")
    release
}

script WaddleDeeTown_Lab_WiseAdvice09
{
    msgbox("{SPEAKER NAME_WISE}Stronger wild Helpers are likely to
            have already evolved at least once.
            
            To register their unevolved forms,
            you'll need to obtain their Helper Egg.
            
            That would lead you to the Helper
            Day Care, where eggs are oft found.")
    release
}

script WaddleDeeTown_Lab_WiseAdvice10
{
    msgbox("{SPEAKER NAME_WISE}I've heard rumors of especially strong
            wild Helpers in remote locations\.
            
            We've been referring to them as
            \qoBig Boss Helpers\qc.
            
            They'll be tough to find, and even
            tougher to recruit, certainly.
            
            There must be some group out there
            that knows a thing or two about
            tracing legendary finds like that\.")
    release
}

script WaddleDeeTown_Lab_WiseAdvice11
{
    msgbox("{SPEAKER NAME_WISE}This might come across as a rather
            silly point of advice, but\.
            remember you're not alone, Kirby.
            
            If there's an empty spot in your
            Info Cards you just can't fill out,
            why not ask a friend for help?
            
            Talk to everyone and work together.
            Friendship is important!")
    release
}

script WaddleDeeTown_Lab_WiseAdvice12
{
    msgbox("{SPEAKER NAME_WISE}This is it, Kirby. You're in the
            homestretch now!
            
            I'm optimistic - nay, COMPELTELY
            confident you'll finish the job.
            
            Go forth, Kirby! Complete the
            Info Card Binder and make me proud!")
    release
}

script WaddleDeeTown_Lab_BinderCheck2
{
    msgbox("{SPEAKER NAME_WISE}Wonderful! You've already registered
            15 Helpers!
            
            As proof of your hard work, please
            accept this care package from me!")
    giveitem_msg(WaddleDeeTown_Lab_ReceivedExpShare, ITEM_EXP_SHARE, 1, MUS_RG_OBTAIN_KEY_ITEM)
    giveitem(ITEM_TM09)
    giveitem(ITEM_BIG_PEARL)
    giveitem(ITEM_DIVE_BALL, 10)
    msgbox("{SPEAKER NAME_WISE}It includes a TM, new Hearts, some
            valuables, and most importantly:
            the Experience Share!
            
            This tool simplifies training Helpers by
            giving experience to your whole party.
            
            Hopefully it makes filling out your
            Info Card Binder a bit easier!")
    setflag(FLAG_BINDER_GATE_02)
    if(var(VAR_0x8009) >= 30 && !flag(FLAG_BINDER_GATE_03))
        {
            call(WaddleDeeTown_Lab_BinderCheck3)
        }
}

