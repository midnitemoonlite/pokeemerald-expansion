script WaddleDeeTown_Lab_EventScript_LeftReceptionist
{
    lock
    faceplayer
    msgbox("Welcome to the Waddle Dee Library. 
            If you're looking for Wise Waddle Dee,
            his lab is located in the back.")
    release
}

script WaddleDeeTown_Lab_EventScript_RightReceptionist
{
    lock
    faceplayer
    msgbox("Welcome to the labrary!
    
            Do you get it? \qoLab\qcrary? Like a library
            and a laboratory in one?
            
            Ah ha haaa\. ahem.")
    release
}

script WaddleDeeTown_Lab_EventScript_Chef
{
    lock
    faceplayer
    msgbox("I'm in charge of keeping all of the
            library's books organized.
            
            Make sure to place any books you
            take out back where they belong!")
    release
}

script WaddleDeeTown_Lab_EventScript_Youngster
{
    lock
    faceplayer
    msgbox("I love playing games on the computer.
            They're tons of fun!")
    release
}

script WaddleDeeTown_Lab_EventScript_Gentleman
{
    lock
    faceplayer
    msgbox("I've made many visits to this library
            over the years, but I feel like there's
            still so much I haven't read here\.")
    release
}

script WaddleDeeTown_Lab_EventScript_LeftAstronomer
{
    lock
    faceplayer
    msgbox("Have you been checking your Info Cards
            as you catch more Helpers?
            
            You'll find comprehensive data on
            movesets, evolutions, and the like\.
            
            It's hard to fit so much into those
            small cards, but we make it work!")
    release
}

script WaddleDeeTown_Lab_EventScript_WaddleDee
{
    lock
    faceplayer
    msgbox("The number of discovered Helpers so
            far is close to 300.
            
            Wouldn't it be nice if it were 300
            on the dot? What a nice, round number!")
    release
}

script WaddleDeeTown_Lab_EventScript_RightAstronomer
{
    lock
    faceplayer
    msgbox("I've been trying to reverse engineer
            these PCs, thinking it might help
            us understand Helpers better\.
            
            Are you curious to hear what
            I've learned so far?", MSGBOX_YESNO)
    if(var(VAR_RESULT))
    {
        msgbox("You might be surprised to learn this,
                but they're King Dedede's design.
                
                It seems this was his stopgap solution
                for curbing wild Helper numbers.
                
                Though, for as brilliant a mechanic as
                the Great King is, it seems that
                even he couldn't do this alone.
                
                It seems he contracted some parts to a
                group I don't recognize.
                
                Specifically, they handled operations
                for the PC's \qomemory banks\qc.
                
                Now, there's no physical storage
                involved with the PC networks.
                
                Instead, Helpers go through a process
                of conversion when placed inside\.
                
                But it's no simple data conversion,
                meaning Helpers aren't synthetic.
                
                It might be plausible they aren't
                entirely natural creatures either\.
                
                As if they were brought to Dream
                Land through some other force.
                
                That would explain their rather
                abrupt appearance, wouldn't it?")
                setflag(FLAG_SYS_PC_LANETTE)
    }
    elif(!var(VAR_RESULT))
    {
        msgbox("I get it\. it's complicated stuff!")
    }
    turnobject(LOCALID_LAB_PC_DEE, DIR_NORTH)
    release
}

script WaddleDeeTown_Lab_EventScript_BWD
{
    lock
    faceplayer
    msgbox("{SPEAKER NAME_BANDANA}So, Kirby, what's next for you? Are you
            planning on challenging more Arenas?
            
            Once I score a Brooch in town, my plan
            was to head up north\.
            
            With the town in the state it is now,
            though, I'll have to go the long way
            by heading eastward first.
            
            I overheard someone say the Great King
            has a lot of soldiers up there\.
            did something happen there, I wonder?")
    release
}

script WaddleDeeTown_Lab_EventScript_WiseWaddleDee
{
    goto_if_eq(VAR_WADDLE_DEE_TOWN_STATE, 3, WaddleDeeTown_Lab_EventScript_WiseGateCheck)
    goto_if_eq(VAR_WADDLE_DEE_TOWN_STATE, 4, WaddleDeeTown_Lab_EventScript_WiseGateCheckRetry)
    goto_if_ge(VAR_WADDLE_DEE_TOWN_STATE, 5, WaddleDeeTown_Lab_EventScript_InfoCardRating)
}

script WaddleDeeTown_Lab_EventScript_WiseGateCheck
{
    lockall
    specialvar(VAR_RESULT, GetPlayerFacingDirection)
    if(var(VAR_RESULT) == DIR_NORTH)
    {
        turnobject(LOCALID_LAB_BWD, DIR_NORTH)
        applymovement(LOCALID_PLAYER, moves(walk_down, walk_in_place_up))
    }
    elif(var(VAR_RESULT) == DIR_WEST)
    {
        turnobject(LOCALID_LAB_BWD, DIR_NORTH)
        applymovement(LOCALID_PLAYER, moves(walk_down, walk_left, walk_down, walk_in_place_up))
    }
    waitmovement()
    delay(15)
    setvar(VAR_WADDLE_DEE_TOWN_STATE, 4)
    applymovement(LOCALID_LAB_WISE, moves(walk_in_place_down))
    waitmovement()
    msgbox("{SPEAKER NAME_WISE}It's good to see you again, Kirby!
    
            Bandana Waddle Dee has filled me in.
            Congratulations on your first Brooch!
            
            Collecting the Brooches will take
            you all across Dream Land.
            
            I'm positive you'll meet all sorts
            of Helpers along the way.
            
            Now, there's a certain matter I wished
            to discuss with you, Kirby\.
            
            It seems the king has taken a great
            interest in your Info Card collection.
            
            So much so, in fact, that he wants
            to personally oversee its completion!
            
            As you'll travel, you'll encounter
            fellow Helper researchers who will
            {COLOR RED}check your cards for progress{COLOR DARK_GRAY}.
            
            Please make sure not to neglect your
            card-completing duties!
            
            In exchange for these progress checks,
            we'll provide you with care packages.
            
            In fact, I have one right here!
            Kirby, have you recruited {COLOR RED}6 Helpers{COLOR DARK_GRAY}?")
    call(WaddleDeeTown_Lab_EvaluateCards)
    if(var(VAR_0x8009) >= 6)
    {
        goto(WaddleDeeTown_Lab_EventScript_WiseGateCheckSuccess)
    }
    elif(var(VAR_0x8009) < 6)
    {
        goto(WaddleDeeTown_Lab_EventScript_WiseGateCheckFailure)
    }
}

