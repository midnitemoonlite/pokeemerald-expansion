raw `
KirbysHouse_Indoors_MapScripts::
	map_script MAP_SCRIPT_ON_TRANSITION, KirbysHouse_Indoors_OnTransition
	.byte 0

KirbysHouse_Indoors_OnTransition:
	setrespawn HEAL_LOCATION_KIRBYS_HOUSE
	end

KirbysHouse_Indoors_EventScript_PC::
	lockall
	setvar VAR_0x8004, PC_LOCATION_BRENDANS_HOUSE
	special DoPCTurnOnEffect
	playse SE_PC_ON
	msgbox gText_PlayerHouseBootPC, MSGBOX_DEFAULT
	special BedroomPC
	waitstate
	releaseall
	end

KirbysHouse_Indoors_EventScript_TurnOffPlayerPC::
	setvar VAR_0x8004, PC_LOCATION_BRENDANS_HOUSE
	playse SE_PC_OFF
	special DoPCTurnOffEffect
	releaseall
	end

KirbysHouse_Indoors_EventScript_GameCube::
	msgbox KirbysHouse_Indoors_Text_ItsAGameCube, MSGBOX_SIGN
	end

KirbysHouse_Indoors_EventScript_WallClock::
	goto_if_set FLAG_SET_WALL_CLOCK, KirbysHouse_Indoors_EventScript_CheckWallClock
	msgbox KirbysHouse_Indoors_Text_ClockIsStopped, MSGBOX_DEFAULT
	call KirbysHouse_Indoors_EventScript_SetWallClock
	delay 30
	setflag FLAG_SET_WALL_CLOCK
	playse SE_EXIT
	removeobject VAR_0x8008
	releaseall
	end

KirbysHouse_Indoors_EventScript_CheckWallClock::
	incrementgamestat GAME_STAT_CHECKED_CLOCK
	fadescreen FADE_TO_BLACK
	special Special_ViewWallClock
	waitstate
	releaseall
	end

KirbysHouse_Indoors_EventScript_SetWallClock::
	fadescreen FADE_TO_BLACK
	special StartWallClock
	waitstate
	return

KirbysHouse_Indoors_Text_ItsAGameCube:
	.string "It's a Nintendo GameCube.\p"
	.string "A Game Boy Advance is connected to\n"
	.string "serve as the Controller.$"

KirbysHouse_Indoors_Text_ClockIsStopped:
	.string "It's a brand-new clock.\p"
	.string "Let's set it and start it!$"
`

script KirbysHouse_Indoors_EventScript_Fridge
{
	lock
	msgbox("The fridge is packed to the brim with
			delicious-looking foods\.!
			
			You resist your urges and close the
			fridge door."
			)
	release
}

script KirbysHouse_Indoors_GoToSleep
{
	if(var(VAR_KIRBYS_HOUSE_STATE) >= 4)
	{
		lock
		msgbox("It's your bed... time to take a nap!")
		closemessage
		fadescreenswapbuffers(FADE_TO_BLACK)
		playfanfare(MUS_HEAL)
		waitfanfare()
		special(HealPlayerParty)
		fadescreenswapbuffers(FADE_FROM_BLACK)
		msgbox("You and your Helpers are all rested up!")
		closemessage
		release
	}
}

script KirbysHouse_Indoors_TalkToGooey
{
	faceplayer
	lock
	if(var(VAR_KIRBYS_HOUSE_STATE) == 0)
	{
		msgbox("{COLOR BLUE}GOOEY:{COLOR DARK_GRAY} Goo?
				
				It's Gooey. He lives here too.")
		release
	}
	elif(var(VAR_KIRBYS_HOUSE_STATE) == 1)
	{
		msgbox("{COLOR BLUE}GOOEY:{COLOR DARK_GRAY} Goo\.
				
				It's Gooey. He's staring intently at the
				television.")
		release
		setobjectmovementtype(LOCALID_GOOEY, MOVEMENT_TYPE_FACE_UP)
		turnobject(LOCALID_GOOEY, DIR_NORTH)
	}
	elif(var(VAR_KIRBYS_HOUSE_STATE) == 2)
	{
		msgbox("{COLOR BLUE}GOOEY:{COLOR DARK_GRAY} Goo!
				
				It's Gooey. Doesn't seem like he
				understood the news at all\.")
		release
	}
	elif(var(VAR_KIRBYS_HOUSE_STATE) == 3)
	{
		msgbox("{COLOR BLUE}GOOEY:{COLOR DARK_GRAY} Goooo?
				
				It's Gooey. He seems curious about
				the noise outside.")
		release
	}
}

script KirbysHouse_Indoors_TalkToBandanaWaddleDee
{
    faceplayer
	lock
	msgbox("{COLOR BLUE}BANDANA WADDLE DEE:{COLOR DARK_GRAY} What are you
			waiting for? Let's turn on the TV!")
	release
	turnobject(LOCALID_BANDANA_WADDLE_DEE, DIR_NORTH)
}

script KirbysHouse_Indoors_BandanaDeeEntranceBottomLeft
{
	if(var(VAR_KIRBYS_HOUSE_STATE) == 0)
	{
		lockall
		setobjectmovementtype(LOCALID_GOOEY, MOVEMENT_TYPE_FACE_UP)
		setobjectxyperm(LOCALID_BANDANA_WADDLE_DEE, 6, 13)
		addobject(LOCALID_BANDANA_WADDLE_DEE)
		playse(SE_EXIT)
		delay(35)
		turnobject(LOCALID_BANDANA_WADDLE_DEE, DIR_WEST)
		applymovement(LOCALID_PLAYER, moves(
			walk_in_place_faster_right
		))
		waitmovement(0)
		msgbox(KirbysHouse_Indoors_BandanaDeeIntroduction)
		closemessage
		applymovement(LOCALID_BANDANA_WADDLE_DEE, moves(
			walk_right * 2
			walk_up * 8
		))
		waitmovement(0)
		setvar(VAR_KIRBYS_HOUSE_STATE, 1)
		releaseall
	}
}

