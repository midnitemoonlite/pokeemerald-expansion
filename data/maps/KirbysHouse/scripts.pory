text KirbysHouse_Text_AlreadyChoseStarter
{
	"You've already picked a Helper! Make
	sure to let Wise Waddle Dee know."
}

script KirbysHouse_EventScript_DontEnterHouse
{
		lock
		msgbox("You can't go home and nap now! There's
				still unfinished business to handle.")
		closemessage
		applymovement(LOCALID_PLAYER, moves(walk_down))
		waitmovement(0)
		release
}

script KirbysHouse_EventScript_AfterChoosingStarter
{
	turnobject(LOCALID_WISE_WADDLE_DEE, DIR_SOUTH)
	turnobject(LOCALID_BANDANA_WADDLE_DEE, DIR_NORTH)
	getobjectfacingdirection(LOCALID_PLAYER, VAR_TEMP_0)
	if(var(VAR_TEMP_0) == DIR_NORTH)
	{
		applymovement(LOCALID_PLAYER, moves(walk_left, walk_in_place_up))
		waitmovement()
	}
	elif(var(VAR_TEMP_0) == DIR_SOUTH)
	{
		applymovement(LOCALID_PLAYER, moves(walk_left, walk_down * 2, walk_in_place_up))
		waitmovement()
	}
	elif(var(VAR_TEMP_0) == DIR_WEST)
	{
		applymovement(LOCALID_PLAYER, moves(walk_up, walk_left * 2, walk_down * 2, walk_in_place_up))
		waitmovement()
	}
	elif(var(VAR_TEMP_0) == DIR_EAST)
	{
		applymovement(LOCALID_PLAYER, moves(walk_down, walk_in_place_up))
		waitmovement()
	}
	msgbox("{SPEAKER NAME_WISE}To chronicle any Helpers you encounter,
			I'll give you these.")
	closemessage
	applymovement(LOCALID_WISE_WADDLE_DEE, moves(walk_in_place_down, walk_left, face_player, walk_in_place_down))
	waitmovement()
	playfanfare(MUS_RG_OBTAIN_KEY_ITEM)
	msgbox("Kirby received an {COLOR RED}Info Card Binder{COLOR DARK_GRAY}!")
	waitfanfare
	setflag(FLAG_SYS_POKEDEX_GET)
	special(SetUnlockedPokedexFlags)
	msgbox("{SPEAKER NAME_WISE}These info cards hold data on Helpers
			you find and recruit to your side.
			
			As for how to recruit Helpers, you'll
			want to use Helper Hearts!")
	applymovement(LOCALID_WISE_WADDLE_DEE, moves(walk_in_place_down))
	waitmovement()
	giveitem(ITEM_POKE_BALL, 10)
	if(var(VAR_RESULT) == FALSE)
	{
		msgbox("{SPEAKER NAME_WISE}\.oh dear! Kirby, your sack is full?")
	}
	closemessage
	applymovement(LOCALID_WISE_WADDLE_DEE, moves(walk_right, walk_in_place_down))
	waitmovement()
	msgbox("{SPEAKER NAME_WISE}More Helper Hearts are always available
			to purchase at Rest Areas.
			
			They're invaluable places for stocking
			up on items and healing your Helpers.
			
			Speaking of, our last subject to cover
			is none other than Helper battles!
			
			Rather than lecturing, I think a proper
			demonstration ought to serve you well.
			
			How about one of you take me on?")
	closemessage
	turnobject(LOCALID_PLAYER, DIR_EAST)
	turnobject(LOCALID_BANDANA_WADDLE_DEE, DIR_WEST)
	delay(15)
	msgbox("{SPEAKER NAME_BANDANA}Are you up for this, Kirby?
			
			I think I'd learn a lot from watching
			someone like you take this on.")
	closemessage
	applymovement(LOCALID_WISE_WADDLE_DEE, moves(walk_left, walk_in_place_down))
	waitmovement()
	turnobject(LOCALID_PLAYER, DIR_NORTH)
	waitmovement()
	msgbox("{SPEAKER NAME_WISE}Very well then.
			I shall be your first opponent!")
	closemessage
	switch(var(VAR_STARTER_MON)) {
		case 0:
			trainerbattle_earlyrival(TRAINER_SAWYER_1, RIVAL_BATTLE_TUTORIAL, KirbysHouse_Text_WiseWaddleDeeDefeat, KirbysHouse_Text_WiseWaddleDeeVictory)
		case 1:
			trainerbattle_earlyrival(TRAINER_GRUNT_AQUA_HIDEOUT_1, RIVAL_BATTLE_TUTORIAL, KirbysHouse_Text_WiseWaddleDeeDefeat, KirbysHouse_Text_WiseWaddleDeeVictory)
		case 2:
			trainerbattle_earlyrival(TRAINER_GRUNT_AQUA_HIDEOUT_2, RIVAL_BATTLE_TUTORIAL, KirbysHouse_Text_WiseWaddleDeeDefeat, KirbysHouse_Text_WiseWaddleDeeVictory)
	}
	turnobject(LOCALID_BANDANA_WADDLE_DEE, DIR_NORTH)
	msgbox("{SPEAKER NAME_WISE}I hope that was an insightful
			experience for you two.
			
			Now then, I do believe I should be
			returning to my lab in Waddle Dee Town.
			
			If you make any progress on your Info
			Cards, don't hesitate to drop on by!
			
			Enjoy Dedede's Royal Royale!")
	closemessage
	applymovement(LOCALID_WISE_WADDLE_DEE, moves(walk_up * 5))
	waitmovement()
	delay(35)
	applymovement(LOCALID_PLAYER, moves(walk_in_place_right))
	applymovement(LOCALID_BANDANA_WADDLE_DEE, moves(walk_in_place_left))
	waitmovement()
	msgbox("{SPEAKER NAME_BANDANA}A tournament with Helpers to determine
			who could be Dream Land's next king...
			
			The Great King sure loves to make a big
			spectacle of whatever he does, huh?
			
			Speaking of, I should head back to town
			too. Let's see if he's still there!")
	closemessage
	applymovement(LOCALID_PLAYER, moves(walk_in_place_up))
	applymovement(LOCALID_BANDANA_WADDLE_DEE, moves(walk_up * 6))
	waitmovement()
	removeobject(LOCALID_WISE_WADDLE_DEE)
	removeobject(LOCALID_BANDANA_WADDLE_DEE)
	setflag(FLAG_HIDE_KIRBYS_HOUSE_INTRO_CHARACTERS)
	setvar(VAR_KIRBYS_HOUSE_STATE, 4)
	special(HealPlayerParty)
	releaseall
}

text KirbysHouse_Text_WiseWaddleDeeDefeat
{
	"It seems I still have much to learn!"
}

text KirbysHouse_Text_WiseWaddleDeeVictory
{
	"So close! I can tell you're beginning
	to grasp the depth of Helper battles."
}