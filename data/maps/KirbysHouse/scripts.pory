	waitmoncry()
	delay(35)
	msgbox("It's {COLOR BLUE}Squishy{COLOR DARK_GRAY}, the {COLOR BLUE}Water-type{COLOR DARK_GRAY} Helper!
	
			Will you choose Squishy?", MSGBOX_YESNO)
	if(var(VAR_RESULT) == YES)
