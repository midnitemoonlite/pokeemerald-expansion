}

script WaddleDeeTown_EventScript_LabIsOpen
{
    lockall
    checkobjectat(29, 28)
    if(var(VAR_RESULT))
    {
        addobject(LOCALID_TOWN_BWD)
        setobjectxy(LOCALID_TOWN_BWD, 29, 35)
    }
    else
    {
        addobject(LOCALID_TOWN_BWD)
        setobjectxy(LOCALID_TOWN_BWD, 30, 35)
    }
    applymovement(LOCALID_TOWN_BWD, moves(walk_up * 6))
    waitmovement()
    msgbox("{SPEAKER NAME_BANDANA}There you are, Kirby! What were you\.
            Wait, what's that you've got there?")
    closemessage()
    playse(SE_LEDGE)
    applymovement(LOCALID_TOWN_BWD, moves(jump_in_place_up))
    waitmovement()
    msgbox("{SPEAKER NAME_BANDANA}Is that a Brooch?!
            So you already cleared an Arena\.
            
            You're really something, Kirby!
            Congratulations!
            
            I saw Wise Waddle Dee return to his lab,
            so he asked me to call you over.
            
            It's the building on the right side of
            town. Let's catch up there!")
    closemessage()
    applymovement(LOCALID_TOWN_BWD, moves(walk_down * 6))
    waitmovement()
    removeobject(LOCALID_TOWN_BWD)
    setvar(VAR_WADDLE_DEE_TOWN_STATE, 3)
    release
}

