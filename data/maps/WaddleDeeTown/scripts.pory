script WaddleDeeTown_EventScript_EggDealer
{
    lock
    faceplayer
    if (!flag(FLAG_RECEIVED_CHICK_EGG))
    {
        msgbox("Oh, hello, Kirby! You're helping fill out
            Info Cards for Wise Waddle Dee, right?
            Could I ask you for a favor?
            
            I found this egg caught in the rubble
            cutting off the north half of town.
            I think it might be a Helper's egg.
            
            There's just one problem\. Helper eggs
            incubate as you travel with them.
            
            I couldn't possibly hatch this egg
            when I'm cooped up in a lab all day!
            
            Do you think you could take this
            egg off my hands for me?", MSGBOX_YESNO)
        if(var(VAR_RESULT) == YES)
        {
            msgbox("Oh, thank you! Here you go, then!")
            giveegg(SPECIES_CHICK)
            if(var(VAR_RESULT) == MON_GIVEN_TO_PARTY)
            {
                playfanfare(MUS_RG_OBTAIN_KEY_ITEM)
                message("Kirby received the egg.")
                waitmessage()
                waitfanfare()
                setflag(FLAG_RECEIVED_CHICK_EGG)
                call(Common_EventScript_GetGiftMonPartySlot)
                release
            }
            elif(var(VAR_RESULT) == MON_GIVEN_TO_PC)
            {
                playfanfare(MUS_RG_OBTAIN_KEY_ITEM)
                message("Kirby received an egg in the PC.")
                waitmessage()
                waitfanfare()
                setflag(FLAG_RECEIVED_CHICK_EGG)
                call(Common_EventScript_TransferredToPC)
                release
            }
            elif(var(VAR_RESULT) == MON_CANT_GIVE)
            {
                call(Common_EventScript_NoMoreRoomForPokemon)
                release
            }
        }
        elif(var(VAR_RESULT) == NO)
        {
            msgbox("Oh, alright\. I guess this egg will stay
                    unhatched for a long time then\.")
            release
        }
    }
    elif(flag(FLAG_RECEIVED_CHICK_EGG))
    {
        msgbox("There's a lot we're still learning about
                how Helpers propagate.
                
                Thanks to the newly opened Day Care, we
                know that Helpers can hatch from eggs\.
                
                But there haven't been any signs of
                eggs from outside this town.
                
                It begs the question; do the original
                Helpers come from something else?")
        release
    }    
}

script WaddleDeeTown_Trigger_FirstCutscene
{
    lockall
    applymovement(LOCALID_PLAYER, moves(walk_in_place_right))
    applymovement(LOCALID_TOWN_BWD, moves(walk_in_place_left))
    waitmovement
    delay(15)
    msgbox("{SPEAKER NAME_BANDANA}The Great King's up ahead, Kirby.
            Let's hurry!")
    closemessage
    setvar(VAR_WADDLE_DEE_TOWN_STATE, 1)
    goto(WaddleDeeTown_EventScript_DededeSpeech)
}

script WaddleDeeTown_EventScript_Bandana
{
    lock
    faceplayer
    msgbox("{SPEAKER NAME_BANDANA}The Great King's up ahead, Kirby.
            Let's hurry!")
    closemessage
    setvar(VAR_WADDLE_DEE_TOWN_STATE, 1)
    applymovement(LOCALID_TOWN_BWD, moves(walk_in_place_left))
    applymovement(LOCALID_PLAYER, moves(walk_left, walk_up))
    waitmovement()
    goto(WaddleDeeTown_EventScript_DededeSpeech)
}

script WaddleDeeTown_EventScript_DededeSpeech
{
    applymovement(LOCALID_PLAYER, moves(walk_up * 7))
    applymovement(LOCALID_TOWN_BWD, moves(walk_up * 7))
    delay(12)
    //playse(SE_EXIT)
    //fadescreenswapbuffers(FADE_TO_BLACK)
    //call(WaddleDeeTown_EventScript_PopulateTown)
    //delay(60)
    //fadescreenswapbuffers(FADE_FROM_BLACK)
    waitmovement()
    delay(20)
    special(SpawnCameraObject)
    applymovement(OBJ_EVENT_ID_CAMERA, moves(walk_slow_up * 2))
    fadeoutbgm(2)
    waitmovement()
    delay(15)
    playbgm(MUS_ENCOUNTER_INTERVIEWER, FALSE)
    delay(15)
    msgbox("{SPEAKER NAME_DEDEDE}Looks like some of you have already got
            your own Helpers! Not bad, not bad!
            
            Now, I can't really stop 'ya if you'd
            rather keep 'em as companions\.")
    closemessage
    applymovement(LOCALID_TOWN_KING_DEDEDE, moves(walk_slow_right, walk_in_place_slow_down))
    waitmovement()
    msgbox("{SPEAKER NAME_DEDEDE}\.but what I really wanna see are
            leaders and teams pushed to the limit!
            
            And so, I'm proud to cut the ribbon for
            this town's very own Waddle Dee Arena!
            
            This here castle behind me has a new
            room in the back where the Arena is at.
            
            If ya choose to enter, you'd better be
            ready for a gauntlet of Helper battles!

            Only tournament winners get to go home
            with a shiny new Brooch to their name.")
    closemessage
    applymovement(LOCALID_TOWN_KING_DEDEDE, moves(walk_slow_left, walk_in_place_slow_down))
    waitmovement()
    msgbox("{SPEAKER NAME_DEDEDE}Now then, you're all dismissed!")
    closemessage
    playse(SE_APPLAUSE)
    // Crowd animation
    applymovement(LOCALID_CROWD_2, moves(jump_in_place_up * 6))
    applymovement(LOCALID_CROWD_3, moves(walk_in_place_up * 5))
    applymovement(LOCALID_CROWD_8, moves(walk_in_place_fast_up * 11))
    turnobject(LOCALID_CROWD_1, DIR_WEST)
    turnobject(LOCALID_CROWD_4, DIR_SOUTH)
    delay(6)
    applymovement(LOCALID_CROWD_5, moves(walk_in_place_right))
    applymovement(LOCALID_CROWD_6, moves(walk_in_place_left))
    applymovement(LOCALID_CROWD_9, moves(jump_in_place_up))
    turnobject(LOCALID_CROWD_7, DIR_EAST)
    delay(30)
    turnobject(LOCALID_CROWD_7, DIR_SOUTH)
    turnobject(LOCALID_CROWD_4, DIR_WEST)
    delay(30)
    turnobject(LOCALID_CROWD_1, DIR_EAST)
    applymovement(LOCALID_CROWD_9, moves(jump_in_place_up))
    turnobject(LOCALID_CROWD_7, DIR_WEST)
    delay(30)
    turnobject(LOCALID_CROWD_7, DIR_NORTH)
    applymovement(LOCALID_CROWD_5, moves(walk_in_place_up))
    applymovement(LOCALID_CROWD_6, moves(walk_in_place_up))
    delay(15)
    applymovement(LOCALID_CROWD_9, moves(jump_in_place_up))
    turnobject(LOCALID_CROWD_4, DIR_NORTH)
    delay(15)
    turnobject(LOCALID_CROWD_1, DIR_NORTH)
    delay(15)
    message("Yes, Great King!
            Thank you, Great King!")
    delay(140)
    closemessage()
    applymovement(LOCALID_CROWD_1, moves(walk_left * 2, walk_up * 2, walk_left * 7))
    applymovement(LOCALID_CROWD_2, moves(walk_left, walk_down * 3, walk_right, walk_down * 4))
    applymovement(LOCALID_CROWD_5, moves(walk_left * 3, walk_up * 2, walk_left * 6))
    applymovement(LOCALID_CROWD_6, moves(walk_left * 3, walk_up * 2, walk_left * 7))
    applymovement(LOCALID_CROWD_9, moves(walk_down * 8))
    applymovement(LOCALID_CROWD_8, moves(walk_right * 7))
    applymovement(LOCALID_CROWD_7, moves(walk_right, walk_up, walk_right, walk_up, walk_right, walk_up, walk_right * 5))
    applymovement(LOCALID_CROWD_10, moves(walk_right, walk_up * 3, walk_right * 7))
    applymovement(LOCALID_CROWD_4, moves(walk_up, walk_left * 12))
    applymovement(LOCALID_CROWD_3, moves(walk_slow_right))
    waitmovement()
    playse(SE_LEDGE)
    applymovement(LOCALID_CROWD_3, moves(jump_left))
    waitse()
    delay(20)
    applymovement(LOCALID_CROWD_3, moves(walk_in_place_right))
    waitmovement()
    applymovement(LOCALID_CROWD_3, moves(walk_in_place_left))
    waitmovement()
    delay(20)
    applymovement(LOCALID_CROWD_3, moves(walk_in_place_down))
    waitmovement()
    applymovement(LOCALID_CROWD_3, Common_Movement_ExclamationMark)
    playse(SE_PIN)
    delay(60)
    waitmovement()
    applymovement(LOCALID_CROWD_3, moves(walk_fast_right, walk_fast_down * 7))
    waitmovement()
    applymovement(OBJ_EVENT_ID_CAMERA, moves(walk_slow_down * 2))
    fadeoutbgm(1)
    waitmovement()
    delay(15)
    applymovement(LOCALID_PLAYER, moves(walk_in_place_right))
    applymovement(LOCALID_TOWN_BWD, moves(walk_in_place_left))
    playbgm(MUS_RUSTBORO, FALSE)
    setflag(FLAG_HIDE_CROWD_WADDLE_DEE_TOWN)
    removeobject(LOCALID_CROWD_1)
    removeobject(LOCALID_CROWD_2)
    removeobject(LOCALID_CROWD_3)
    removeobject(LOCALID_CROWD_4)
    removeobject(LOCALID_CROWD_5)
    removeobject(LOCALID_CROWD_6)
    removeobject(LOCALID_CROWD_7)
    removeobject(LOCALID_CROWD_8)
    removeobject(LOCALID_CROWD_9)
    removeobject(LOCALID_CROWD_10)
    waitmovement()
    msgbox("{SPEAKER NAME_BANDANA}Ah, looks like we only caught the end of
            the Great King's speech\.
            
            I wonder how tough the challengers at
            the Arena here will be?")
    applymovement(LOCALID_TOWN_KING_DEDEDE, moves(walk_down * 2))
    msgbox("{SPEAKER NAME_DEDEDE}Well, well, well!
            If it isn't my favorite lil' nuisance!")
    applymovement(LOCALID_PLAYER, moves(walk_in_place_up))
    applymovement(LOCALID_TOWN_BWD, moves(walk_in_place_up))
    waitmovement()
    playse(SE_PIN)
    applymovement(LOCALID_TOWN_BWD, Common_Movement_ExclamationMark)
    waitmovement()
    delay(20)
    playbgm(MUS_ENCOUNTER_BRENDAN, FALSE)
    msgbox("{SPEAKER NAME_BANDANA}G-Great King!
    
            {SPEAKER NAME_DEDEDE}And ol' Bandana too! Well? How about it?
            Ya enjoying the Royal Royale so far?")
    applymovement(LOCALID_TOWN_BWD, moves(walk_in_place_up * 2))
    msgbox("{SPEAKER NAME_BANDANA}Um, it's\. you really put your all into
            this game, Great King! It's impressive!
    
            I'm still learning all sorts of things
            as I go, but I'm enjoying it.
            
            Wise Waddle Dee taught us the basics,
            so now we're helping him in exchange\.")
    applymovement(LOCALID_TOWN_KING_DEDEDE, moves(walk_in_place_slow_down))
    msgbox("{SPEAKER NAME_DEDEDE}Ohh, filling out the Info Cards, ain't
            ya? That's some real great news!
            Even I don't know all the Helpers yet!
            
            {SPEAKER NAME_BANDANA}That reminds me, Wise Waddle Dee said he
            didn't know where Helpers came from.
            Great King, do you\.?")
    playse(SE_LEDGE)
    applymovement(LOCALID_TOWN_KING_DEDEDE, moves(jump_in_place_down))
    waitmovement()
    setvar(VAR_0x8004, 2)  // vertical pan
	setvar(VAR_0x8005, 0)  // horizontal pan
	setvar(VAR_0x8006, 2) // num shakes
	setvar(VAR_0x8007, 3)  // shake delay
	special(ShakeCamera)
    msgbox("{SPEAKER NAME_DEDEDE}Nope! Nuh uh! Couldn't tell ya!
    
            Don't sweat the small details, yeah?
            The most important thing is having fun!")
    closemessage()
    applymovement(LOCALID_TOWN_KING_DEDEDE, moves(walk_in_place_slow_up))
    waitmovement()
    delay(20)
    msgbox("{SPEAKER NAME_DEDEDE}The road to becoming a Great King isn't
            easy. I don't expect most to make it.
    
            But I wanted to put something together
            that could be enjoyed regardless.
            
            I want my subjects to come away from
            this with something new\.")
    closemessage()
    delay(20)
    applymovement(LOCALID_TOWN_KING_DEDEDE, moves(walk_in_place_down))
    msgbox("{SPEAKER NAME_DEDEDE}So, Kirby, huh? Why, I shudder to think
            what HE would be like as king!
            
            I can picture it now... he'd order all
            of Dream Land's food be for himself!
            
            Ha ha haaaa! Whew\.

            Well, that was entertaining enough.
            I'm a busy king, with places to be.
            You'll have to excuse me for now.
            
            Peace!")
    closemessage()
    applymovement(LOCALID_PLAYER, moves(walk_left * 2, walk_in_place_right))
    applymovement(LOCALID_TOWN_BWD, moves(walk_right * 2, walk_in_place_left))
    applymovement(LOCALID_TOWN_KING_DEDEDE, moves(walk_down * 10))
    fadeoutbgm(1)
    delay(30)
    applymovement(LOCALID_PLAYER, moves(walk_right * 2, walk_in_place_down))
    applymovement(LOCALID_TOWN_BWD, moves(walk_left * 2, walk_in_place_down))
    delay(60)
    playbgm(MUS_RUSTBORO, FALSE)
    special(RemoveCameraObject)
    msgbox("{SPEAKER NAME_BANDANA}I hate having to say this, but\.
            He's definitely hiding something, right?
            
            Looks like it's up to us to figure out
            why Dream Land is full of Helpers\.")
    applymovement(LOCALID_PLAYER, moves(walk_in_place_right))
    applymovement(LOCALID_TOWN_BWD, moves(walk_in_place_left))
    msgbox("{SPEAKER NAME_BANDANA}I'm gonna ask around town and see if I
            can figure anything out for myself.
            
            Kirby, why don't you check out the
            Waddle Dee Arena?
            
            You're better at battling than I am, so
            you might have a shot at victory there.
            
            If you can score some Brooches, I'm
            sure the Great King'll recognize you
            as a real contender for the crown!")
    closemessage
    applymovement(LOCALID_TOWN_BWD, moves(walk_up * 3, walk_right * 9))
    waitmovement()
    setflag(FLAG_HIDE_DEDEDE_WADDLE_DEE_TOWN)
    setflag(FLAG_HIDE_BWD_WADDLE_DEE_TOWN)
    removeobject(LOCALID_TOWN_BWD)
    removeobject(LOCALID_TOWN_KING_DEDEDE)
    release
}

script WaddleDeeTown_EventScript_EastGuard
{
    lock
    faceplayer
    msgbox("I'm sorry, but I can't let you pass
            through to Vegetable Valley just yet.
            
            We're doing inspections in the area
            to make sure it's safe for traversal
            following the recent avalanche.")
    release
}

script WaddleDeeTown_EventScript_EastExitBlocked
{
    lock
    playse(SE_PIN)
    applymovement(LOCALID_TOWN_EAST_GUARD, Common_Movement_ExclamationMark)
    waitmovement()
    applymovement(LOCALID_TOWN_EAST_GUARD, moves(walk_in_place_down))
    waitmovement()
    msgbox("Excuse me!

            I'm sorry, but I can't let you pass
            through to Vegetable Valley just yet.
            
            We're doing inspections in the area
            to make sure it's safe for traversal
            following the recent avalanche.")
    closemessage()
    applymovement(LOCALID_PLAYER, moves(walk_left))
    waitmovement()
    release
}

