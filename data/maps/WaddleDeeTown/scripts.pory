script WaddleDeeTown_EventScript_Gentleman
{
    lock
    faceplayer
    msgbox("First, a game shop\.
            Then, a luxury department store\.
            
            He's a skilled craftsman, but soon this
            place will be more Magolor than Dedede!
            Does noone else find this concerning?")
    release
}

script WaddleDeeTown_EventScript_Socialite
{
    lock
    faceplayer
    msgbox("I think it's rather nice seeing
            Waddle Dee Town develop and flourish.
            
            Why would I be worried about Magolor?
            He's such a hardworking, honest fellow!")
    release
}

