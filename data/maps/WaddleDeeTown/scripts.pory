script WaddleDeeTown_EventScript_Fisherman
{
    lock
    faceplayer
    setvar(VAR_0x8004, SPECIES_BLING_BLIPPER)
	specialvar(VAR_RESULT, DoesPlayerPartyContainSpecies)
    if (!flag(FLAG_RECEIVED_SUPER_ROD))
    {
        msgbox("I've heard rumors of a glimmering golden
            fish living in this humble pond.
            
            I haven't caught a glimpse of it yet,
            but that's alright. Fishing is relaxing\.
            
            You wanna try, Kirby? Here, I'll lend
            you one of my spare rods.")
        playfanfare(MUS_RG_OBTAIN_KEY_ITEM)
	    msgbox("Kirby received a {COLOR RED}Fishing Rod{COLOR DARK_GRAY}!")
	    waitfanfare
        msgbox("Kirby put away the Fishing Rod
                in the KEY ITEMS POCKET.")
        additem(ITEM_SUPER_ROD)
        msgbox("Cast your line into any body of water,
                and you might hook up something.")
        setflag(FLAG_RECEIVED_SUPER_ROD)
    }
    elif (flag(FLAG_RECEIVED_SUPER_ROD) && !flag(FLAG_SHOWN_BLING_BLIPPER) && !var(VAR_RESULT))
    {
        msgbox("How's fishing treating you, Kirby?
        
                Me? Well, that golden catch I'm looking
                for still eludes me, I'm afraid.
                
                Oh, what I'd give to see for myself
                if the rumors are true\.")
    }
    elif (flag(FLAG_RECEIVED_SUPER_ROD) && !flag(FLAG_SHOWN_BLING_BLIPPER) && var(VAR_RESULT))
    {
        msgbox("Huh? Is that\.?")
        playse(SE_PIN)
        applymovement(LOCALID_FISHERMAN_WADDLE_DEE, Common_Movement_ExclamationMark)
        delay(60)
        getobjectfacingdirection(LOCALID_FISHERMAN_WADDLE_DEE, VAR_RESULT)
        if (var(VAR_RESULT) == DIR_NORTH)
        {
            applymovement(LOCALID_FISHERMAN_WADDLE_DEE, moves(walk_in_place_fast_up * 4, walk_in_place_faster_up * 4))
            waitmovement()
            playse(SE_LEDGE)
            applymovement(LOCALID_FISHERMAN_WADDLE_DEE, moves(jump_in_place_up))
            waitmovement()
        }
        elif (var(VAR_RESULT) == DIR_WEST)
        {
            applymovement(LOCALID_FISHERMAN_WADDLE_DEE, moves(walk_in_place_fast_left * 4, walk_in_place_faster_left * 4))
            waitmovement()
            playse(SE_LEDGE)
            applymovement(LOCALID_FISHERMAN_WADDLE_DEE, moves(jump_in_place_left))
            waitmovement()
        }
        elif (var(VAR_RESULT) == DIR_SOUTH)
        {
            applymovement(LOCALID_FISHERMAN_WADDLE_DEE, moves(walk_in_place_fast_down * 4, walk_in_place_faster_down * 4))
            waitmovement()
            playse(SE_LEDGE)
            applymovement(LOCALID_FISHERMAN_WADDLE_DEE, moves(jump_in_place_down))
            waitmovement()
        }
        msgbox("No! It c-can't be...! Kirby, you CAUGHT
                the legendary golden fish?!
                
                Unbelievable! It's HUGE! And that sheen
                is even shinier than I imagined!
                
                Ahaha\. it's real! The glimmering
                golden Bling Blipper is actually real!
                
                I may not have caught one myself, but
                just seeing it is enough to satisfy me.
                
                Here, let me give you a little
                token of my appreciation.")
        giveitem(ITEM_BIG_NUGGET, 10)
        msgbox("It might seem like a lot, but trust me:
                this gold is nothing compared to the 
                legendary Bling Blipper.
                
                You can put the treasure I've fished
                up to better use than I could.")
        setflag(FLAG_SHOWN_BLING_BLIPPER)
    }
    else
    {
        msgbox("Thank you, Kirby. Seeing that Bling
        Blipper has given me peace of mind.
        
        And fishing is already peaceful\. I
        couldn't be more relaxed if I tried!")
    }
    turnobject(LOCALID_FISHERMAN_WADDLE_DEE, DIR_EAST)
    release
}

script WaddleDeeTown_EventScript_ParkWaddleDee
{
    lock
    faceplayer
    msgbox("The Great King made this garden for us
            to enjoy with his own two hands.
            
            I heard he's thinking about building a
            playground here too. I'd love that!")
    release
}

script WaddleDeeTown_EventScript_CastleGuardLeft
{
    lock
    faceplayer
    msgbox("The Great King doesn't visit often;
            this is like a vacation home to him.
            
            In exchange for maintaining the place
            while he's gone, we're allowed to
            reside within the castle walls.")
    release
}

script WaddleDeeTown_EventScript_CastleGuardRight
{
    lock
    faceplayer
    msgbox("The Great King has all sorts of castles,
            but his favorite is up on Mt. Dedede.
            
            Must be nice to serve as a guard there.
            You'd get a great view of Dream Land!")
    release
}

