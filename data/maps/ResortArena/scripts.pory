{
    setvar(VAR_0x8005, MOVE_TRICK_ROOM)
    special(BufferBattleFrontierTutorMoveName)
    checkmoney(1000)
    if(!var(VAR_RESULT))
    {
        goto(WaddleDeeArena_EventScript_CantAfford)
    }
    move_tutor(MOVE_TRICK_ROOM, WaddleDeeArena_Text_TeachMove, WaddleDeeArena_Text_SelectMon, WaddleDeeArena_EventScript_MoveTutorLeave, ResortArena_EventScript_TaughtMove)
}

script ResortArena_EventScript_Move5
{
    setvar(VAR_0x8005, MOVE_SLEEP_TALK)
    special(BufferBattleFrontierTutorMoveName)
    checkmoney(1000)
    if(!var(VAR_RESULT))
    {
        goto(WaddleDeeArena_EventScript_CantAfford)
    }
    move_tutor(MOVE_SLEEP_TALK, WaddleDeeArena_Text_TeachMove, WaddleDeeArena_Text_SelectMon, WaddleDeeArena_EventScript_MoveTutorLeave, ResortArena_EventScript_TaughtMove)
}

script ResortArena_EventScript_TaughtMove
{
    showmoneybox(0,0)
    delay(16)
    removemoney(1000)
    updatemoneybox()
    playse(SE_SHOP)
    msgbox("All done! I hope you and your Helper will
            make the most of this new technique!")
	copyvar(VAR_0x8004, VAR_0x8008)
    hidemoneybox()
    release
}

script ResortArena_EventScript_Courtship
{
    applymovement(LOCALID_DAROACH, moves(walk_in_place_right * 3))
    waitmovement()
    msgbox("{SPEAKER NAME_DAROACH}Ladies, ladies! Please, one at a time!
    
            My purloining claws can only steal so
            many hearts at once, you know\.?")
    closemessage()
    applymovement(LOCALID_RESORT_LADY_1, moves(walk_in_place_faster_left * 5))
    applymovement(LOCALID_RESORT_LADY_2, moves(walk_in_place_faster_left * 5))
    applymovement(LOCALID_RESORT_LADY_3, moves(walk_in_place_faster_left * 5))
    waitmovement()
    delay(8)
    msgbox("Eeeeee! Oh, Daroach\.\.! {EMOJI_HEART}{EMOJI_HEART}{EMOJI_HEART}")
    release
}

script ResortArena_EventScript_Socialite
{
    lock
    if(!flag(FLAG_BADGE02_GET))
    {
        goto(ResortArena_EventScript_Courtship)
    }
    else
    {
        faceplayer
        msgbox("You may be stronger than Daroach,
                but you'll never be as suave.
                
                Sigh\. Daroach\. {EMOJI_HEART}")
        release
    }
}

script ResortArena_EventScript_ParasolLady
{
    lock
    if(!flag(FLAG_BADGE02_GET))
    {
        goto(ResortArena_EventScript_Courtship)
    }
    else
    {
        faceplayer
        msgbox("So you beat Daroach at the Arena, huh?
                Maybe I should be your fan instead.
                
                What do you say? Any room in your
                party for a gal like me? {EMOJI_HEART}")
        release
    }
}

script ResortArena_EventScript_Lass
{
    lock
    if(!flag(FLAG_BADGE02_GET))
    {
        goto(ResortArena_EventScript_Courtship)
    }
    else
    {
        faceplayer
        msgbox("I'm over Daroach. I found a new love\.
        
                Why, it's the muscle of the Squeaks,
                Storo!
                
                Who needs brains when you've got all
                that brawn? {EMOJI_HEART}")
        release
    }
}

script ResortArena_EventScript_Daroach
{
    lock
    if(!flag(FLAG_BADGE02_GET))
    {
        goto(ResortArena_EventScript_Courtship)
    }
    if(flag(FLAG_BADGE02_GET))
    {
        faceplayer
        if(!flag(FLAG_RECEIVED_TM_BULK_UP))
        {
            if(!flag(FLAG_FOUND_KINE))
            {
                msgbox("I've underestimated you, my friend.
                    You may have what it takes\.
                    
                    Here, as a sign of good will, let me
                    impart a little something onto you.")
                giveitem(ITEM_TM73)
                msgbox("Power Gem is my personal favorite move.
                        Simple, effective, and flashy! 
                        
                        By the way, I have a tip you might want
                        to hear about\.
                        
                        As it happens, I recently came across a
                        message in a bottle on the shore here.
                        
                        A request for help seeking a precious
                        lost item, by a familiar fishy friend\.
                        
                        Normally I would take such matters into
                        my own claws, but I believe you would
                        be better off looking into it yourself.
                        
                        The correspondent is awaiting on the
                        other side of Cocoa Cave.
                        
                        Don't worry! I'll arrange for the path
                        to be made clear for you\.
                        
                        Now go on! It's time for your own
                        treasure hunt to unfold!")
            }
            else
            {
                msgbox("I've underestimated you, my friend.
                    You may have what it takes\.
                    
                    Here, as a sign of good will, let me
                    impart a little something onto you.")
                giveitem(ITEM_TM73)
                msgbox("Power Gem is my personal favorite move.
                        Simple, effective, and flashy!")
            }
            setflag(FLAG_RECEIVED_TM_BULK_UP)
        }
        else
        {
            if(!flag(FLAG_FOUND_KINE))
            {
                msgbox("By the way, I have a tip you might want
                        to hear about\.
                        
                        As it happens, I recently came across a
                        message in a bottle on the shore here.
                        
                        A request for help seeking a precious
                        lost item, by a familiar fishy friend\.
                        
                        Normally I would take such matters into
                        my own claws, but I believe you would
                        be better off looking into it yourself.
                        
                        The correspondent is awaiting on the
                        other side of Cocoa Cave.
                        
                        Don't worry! I'll arrange for the path
                        to be made clear for you\.
                        
                        Now go on! It's time for your own
                        treasure hunt to unfold!")
            }
            else
            {
                msgbox("My most esteemed cohorts are searching
                    for clues on various Big Boss Helpers.
                    
                    And the little ones are looking for
                    sunken treasure at the beach\.
                    
                    As for me? I think I shall stay a
                    while longer yet at the resort.
                    
                    The sea breeze is good for my fur,
                    and I have many a confidant to make\.")
            }
        }
        release
    }
}

script ResortArena_EventScript_Commentator
{
    lock
    faceplayer
    if(flag(FLAG_BADGE02_GET))
    {
        msgbox("Once more: congraaaaatulations on your
                fantaaaaabulous win, Kirby!
                
                Daroach was a sneaky foe, but you
                carved your own path to victory!
                
                I'll be rooting for you at the other
                Arenas! Good luck, Kirby of the Stars!")
    }
    elif(!flag(FLAG_BADGE02_GET))
    {
        lock
        faceplayer
        msgbox("Wwwwwelcome to the Resort
                Arenaaaaa!
                
                I'm your host, Commentator Waddle Dee,
                here to officiate heated Helper brawls!")
        if(!flag(FLAG_GRAND_FINALS_ACTIVE))
        {
            goto(ResortArena_EventScript_CommentatorChoice)
        }
        elif(flag(FLAG_GRAND_FINALS_ACTIVE))
        {
            msgbox("Next up: grand finals!
                    Are you prepared for the last battle?", MSGBOX_YESNO)
            if(var(VAR_RESULT))
            {
                closemessage
                goto(ResortArena_EventScript_GrandFinalsPreparation)
            }
            elif(!var(VAR_RESULT))
            {
                closemessage
                goto(ResortArena_EventScript_CommentatorBye)
            }
        }
	}
    release
}

script ResortArena_EventScript_CommentatorChoice
{
    message("Today's challenge: a mild stroll!
            How can I help you?")
    waitmessage
    multichoice(20, 6, MULTI_CHALLENGEINFO, FALSE)
    switch(var(VAR_RESULT)) {
	case 0:
		goto(ResortArena_EventScript_BeginChallenge)
	case 1:
		goto(ResortArena_EventScript_CommentatorInfo)
	case 2:
		goto(ResortArena_EventScript_CommentatorBye)
    case MULTI_B_PRESSED:
        goto(ResortArena_EventScript_CommentatorBye)
    }
}

script ResortArena_EventScript_CommentatorBye
{
    if(flag(FLAG_GRAND_FINALS_ACTIVE))
    {
        msgbox("When you're ready for the grand finals,
                you know the Waddle Dee to talk to!")
    }
    else
    {
        msgbox("If you ever want to brave the Arena,
                you know the Waddle Dee to talk to!")
    }
    release
}

script ResortArena_EventScript_CommentatorInfo
{
    msgbox("Arenas host gauntlet-styled
            tournaments of Helper battles.
            
            Eager challengers are first pooled into
            a preliminary bracket. Win more battles
            to climb up the ranks!
            
            In between bouts, leaders are offered
            the chance to rest their Helpers\.
            
            But beware! You only get a limited
            number of heals per attempt!
            
            In this Arena, you'll have to survive
            {COLOR BLUE}5 rounds{COLOR DARK_GRAY} with {COLOR RED}2 full-party heals{COLOR DARK_GRAY}.
            
            If you top the preliminary bracket,
            you'll be entered into grand finals!
            
            You'll have the chance to adjust your
            team and save before the last fight.
            
            Defeat the final opponent, and you'll
            be awarded one Resort Brooch!
            
            Now then\.")
    goto(ResortArena_EventScript_CommentatorChoice)
}

script ResortArena_EventScript_BeginChallenge
{
    msgbox("Alright, you've been signed up.
            Come with me onto the stage, please!")
    closemessage
    setvar(VAR_ARENA_HEALS, 2)
    setvar(VAR_ARENA_BATTLES, 0)
    clearflag(FLAG_ARENA_HEALED_THIS_ROUND)
    getobjectfacingdirection(LOCALID_PLAYER, VAR_TEMP_0)
	if(var(VAR_TEMP_0) == DIR_SOUTH)
	{
        applymovement(LOCALID_RESORT_COMMENTATOR, moves(walk_in_place_down))
		applymovement(LOCALID_PLAYER, moves(walk_left, walk_down * 2, walk_right, walk_in_place_up))
		waitmovement()
	}
	elif(var(VAR_TEMP_0) == DIR_WEST)
	{
		applymovement(LOCALID_RESORT_COMMENTATOR, moves(walk_in_place_down))
		applymovement(LOCALID_PLAYER, moves(walk_down, walk_left, walk_in_place_up))
		waitmovement()
	}
	elif(var(VAR_TEMP_0) == DIR_EAST)
	{
		applymovement(LOCALID_RESORT_COMMENTATOR, moves(walk_in_place_down))
		applymovement(LOCALID_PLAYER, moves(walk_down, walk_right, walk_in_place_up))
		waitmovement()
	}
    special(SpawnCameraObject)
    applymovement(LOCALID_CAMERA, moves(walk_up * 6))
    applymovement(LOCALID_RESORT_COMMENTATOR, moves(walk_up * 7, walk_in_place_down))
    applymovement(LOCALID_PLAYER, moves(walk_up * 6, walk_left * 3, walk_in_place_right))
    waitmovement()
    applymovement(LOCALID_RESORT_COMMENTATOR, moves(walk_in_place_down * 2))
    if(!flag(FLAG_ARENA_RETRY))
    {
        msgbox("Welcome, one and all, to the tropical  
            Resort Arena!
            
            We've got some exciting battles today!
            Including a Waddle Dee Arena champion\.
            It's the mighty marshmallow, Kirbyyy!!!")
    }
    elif(flag(FLAG_ARENA_RETRY))
    {
        msgbox("Welcome, one and all, to the brand-new
            Waddle Dee Arena!
            
            Kirby has returned to the stage for
            another shot at the Resort Brooch!
            Will he see it through this time?")
    }
    playse(SE_APPLAUSE)
    applymovement(LOCALID_RESORT_CROWD_1, moves(face_down))
    applymovement(LOCALID_RESORT_CROWD_2, moves(face_up))
    applymovement(LOCALID_RESORT_CROWD_3, moves(walk_in_place_left * 4))
    delay(60)
    call(ResortArena_EventScript_Challenger1)
}

script ResortArena_EventScript_Challenger1
{
    msgbox("Let's have our first challenger, please!")
    closemessage
    playse(SE_APPLAUSE)
    applymovement(LOCALID_RESORT_CROWD_1, moves(face_right, delay_16, delay_16, delay_16, face_down))
    applymovement(LOCALID_RESORT_CROWD_2, moves(face_right, delay_16, delay_16, delay_16, face_up))
    applymovement(LOCALID_RESORT_CROWD_3, moves(face_down, delay_16, delay_8, face_left, delay_16, delay_8, face_down, delay_16, delay_8, face_left))
    addobject(LOCALID_RESORT_CHALLENGER_1)
    applymovement(LOCALID_RESORT_CHALLENGER_1, moves(walk_up * 7, walk_right * 3, walk_in_place_left))
    waitmovement()
    delay(30)
    applymovement(LOCALID_RESORT_CHALLENGER_1, moves(walk_in_place_left * 2))
    waitmovement()
    clearflag(FLAG_ARENA_HEALED_THIS_ROUND)
    if(!flag(FLAG_ARENA_RETRY))
    {
        msgbox("Oh dear\. I wasn't expecting such a
                strong-looking challenger today\.")
    }
    elif(flag(FLAG_ARENA_RETRY))
    {
        msgbox("You\. you humiliated me last time!
                Now, I'll humiliate you in turn!")
    }
    closemessage
    setflag(FLAG_ARENA_RETRY)
    applymovement(LOCALID_RESORT_CHALLENGER_1, moves(walk_left * 2))
    applymovement(LOCALID_PLAYER, moves(walk_right * 2))
    waitmovement()
    special(RemoveCameraObject)
    trainerbattle_no_intro(TRAINER_ROSE_5, ResortArena_Text_Challenger1)
    msgbox("Is this the start of another sweep?
            Kirby takes the first win!")
    applymovement(LOCALID_RESORT_CROWD_1, moves(face_right, delay_16, delay_16, delay_16, delay_16, delay_16, face_down))
    applymovement(LOCALID_RESORT_CROWD_2, moves(face_right, delay_16, delay_16, delay_16, face_up))
    applymovement(LOCALID_RESORT_CROWD_3, moves(face_up, delay_16, face_right, delay_16, face_down, delay_16, face_left))
    playse(SE_APPLAUSE)
    closemessage
    setvar(VAR_ARENA_BATTLES, 1)
