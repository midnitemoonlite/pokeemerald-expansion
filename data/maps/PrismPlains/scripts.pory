raw `
PrismPlains_MapScripts::
	.byte 0
`

script PrismPlains_EventScript_Sign
{
    msgbox("PRISM PLAINS
            Mind your step on this hilltop road.", MSGBOX_SIGN)
    closemessage
}

script PrismPlains_EventScript_WaddleDeeRunning
{
    lock
    faceplayer
    msgbox("Hup, hup\.
    
            I like to jog up and down the hills, but
            today it's been nothing but others
            asking for Helper battles.
            
            Hup, hup\. can't they see I'm just an
            ordinary Waddle Dee?
            
            If you're moving forward, be ready
            for challenges. Hup, hup\.")
    release
}

script PrismPlains_EventScript_WaddleDeeLedgeJump
{
    if(!flag(FLAG_TEMP_16))
    {
        lock
        msgbox("One\.
                
                Two\.
                
                Three!")
        closemessage
        applymovement(LOCALID_LEDGE_WADDLE_DEE, moves(jump_2_down, walk_down))
        waitmovement()
        setobjectxyperm(LOCALID_LEDGE_WADDLE_DEE, 5, 29)
        setflag(FLAG_TEMP_16)
        release
    } elif(flag(FLAG_TEMP_16))
    {
        lock
        faceplayer
        msgbox("Jumping down ledges is so much fun!")
        release
    }
 }

script PrismPlains_EventScript_WaddleDeeRocky
{
    lock
    faceplayer
    msgbox("I'm surprised you found your way
            through here.
            
            This place is my secret spot\. I like
            navigating around all the rocks here.")
    release
}

script PrismPlains_EventScript_EnteringTown1
{
    lock
    faceplayer
    msgbox("You are now approaching one of the
            Great King's many castles.
            
            His Majesty has recently arrived in
            town. Don't try anything funny!")
    release
}

script PrismPlains_EventScript_EnteringTown2
{
    lock
    faceplayer
    msgbox("Waddle Dee Town is just up ahead.
            I doubt I need to tell you, Kirby, but\.
            Be on your best behavior, okay?")
    release
}

script PrismPlains_EventScript_Trainer1
{
    trainerbattle_single(TRAINER_GRUNT_SEAFLOOR_CAVERN_2, PrismPlains_Text_Trainer1Intro, PrismPlains_Text_Trainer1Defeated)
    msgbox(PrismPlains_Text_Trainer1Post, MSGBOX_AUTOCLOSE)

}

