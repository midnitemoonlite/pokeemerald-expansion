    trainerbattle_single(TRAINER_ALBERTO, PrismPlains_Text_Trainer6Intro, PrismPlains_Text_Trainer6Defeated)
    msgbox(PrismPlains_Text_Trainer1Post, MSGBOX_AUTOCLOSE)

}

text PrismPlains_Text_Trainer1Intro
{
    "Alright! It's time for my very first
     battle of Dedede's Royal Royale!"
}

text PrismPlains_Text_Trainer1Defeated
{
    "Maybe making my first battle against
     Kirby was bound to end like this\."
}

text PrismPlains_Text_Trainer1Post
{
    "Oh well, there's no shame in losing.
     You did great, Kirby!"
}

text PrismPlains_Text_Trainer2Intro
{
    "A battle on a bridge!
     Doesn't it sound exciting?"
}

text PrismPlains_Text_Trainer2Defeated
{
    "Whoa! I almost fell off!"
}

text PrismPlains_Text_Trainer2Post
{
    "Don't worry! Even if I did fall, my
    parasol would keep me safe!"
}

text PrismPlains_Text_Trainer3Intro
{
    "I tried challenging the Castle Arena,
     but it was really tough\."
}

text PrismPlains_Text_Trainer3Defeated
{
    "Is that what a good leader is like?"
}

text PrismPlains_Text_Trainer3Post
{
    "How should I make my Helpers stronger?
     Maybe I can teach them new moves\."
}

text PrismPlains_Text_Trainer4Intro
{
    "I've got a bunch of Helpers already!
     I can win this battle easily!"
}

text PrismPlains_Text_Trainer4Defeated
{
    "Whaaaat? That didn't work?"
}

text PrismPlains_Text_Trainer4Post
{
    "I understand my weakness now\.
     I need to catch MORE Beanbons!"
}

text PrismPlains_Text_Trainer5Intro
{
    "Surprise!"
}

text PrismPlains_Text_Trainer5Defeated
{
    "Did I shock you?"
}

text PrismPlains_Text_Trainer5Post
{
    "It's hard to see down those ledges
    thanks to the rocks. This is the
    perfect spot to surprise them!"
}

text PrismPlains_Text_Trainer6Intro
{
    "Hup, hup! Hi, Kirby! Are you up for a
     Helper battle?"
}

text PrismPlains_Text_Trainer6Defeated
{
    "Hup, hup\. stumble\. you got me!"
}

text PrismPlains_Text_Trainer6Post
{
    "Jogging up and down these hills is more
     exciting than ever now. Hup, hup...!"
}